# Data source switch for the whole application.
# "mock" -> repositories return predefined dummy JSON, no network calls are made.
# "api"  -> repositories call the real EMS backend over HTTP.
# This is the ONLY setting that should change to switch data sources; no UI or
# component code should ever need to change alongside it.
VITE_DATA_SOURCE=mock

# Base URL of the EMS backend API (only used when VITE_DATA_SOURCE=api).
VITE_API_BASE_URL=https://localhost:7284/api/v1
