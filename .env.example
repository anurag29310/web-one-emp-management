POSTGRES_USER=ems
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=ems_db
JWT__KEY=replace_with_secure_random_key_base64
# Example: JWT__KEY=V3JhcHBlZF9ieV9kZW1vX3NlY3JldA==
# Not needed when serving through the docker-compose.prod.yml nginx reverse proxy (it puts the
# frontend and API on the same origin). Set this only if the API is ever reachable on its own
# origin, e.g. Cors__AllowedOrigins__0=https://app.example.com
# Add other settings your app requires (SMTP, storage connection strings, etc.)
